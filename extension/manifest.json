{
  "manifest_version": 3,
  "name": "ISITSAFE",
  "version": "0.1.0",
  "description": "Flags suspicious links and pages before you interact with them.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["content.js", "sender-verify.js"],
      "run_at": "document_idle"
    }
  ]
}
